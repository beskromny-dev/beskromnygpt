# OpenRouter — unified provider for ALL LLM calls (posts, /ask, voice profile, digest)
OPENROUTER_API_KEY=sk-or-...
# Optional model overrides (defaults set in core/config.py)
# OPENROUTER_VOICE_MODEL=anthropic/claude-opus-4.7
# OPENROUTER_DIGEST_MODEL=google/gemini-3.1-pro-preview

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Telegram Userbot (Telethon — Saved Messages)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# LiveDune API (channel analytics)
LIVEDUNE_API_KEY=

# T-Bank Business API (revenue analytics — optional)
TBANK_API_TOKEN=

# Search API for digest Tier 2 (Google Custom Search — 100 free/day)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# Brave Search (backup, optional)
BRAVE_SEARCH_API_KEY=

# Access control
OWNER_ID=0
EDITOR_IDS=  # comma-separated Telegram user IDs of editors
